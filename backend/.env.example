# === GitHub Reporter – Environment Variables ===

# GitHub App credentials (register at https://github.com/settings/apps)
# Use the Client ID (not the App ID) and generate a client secret in the App settings.
GITHUB_APP_CLIENT_ID=your_client_id
GITHUB_APP_CLIENT_SECRET=your_client_secret
GITHUB_APP_SLUG=your-app-slug

ADMIN_GITHUB_LOGIN=your-github-username
REQUIRE_ACCESS_CODE=true

# Plans & usage limits (productization)
# Default plan tier for new users — see backend/app/services/plans.py
DEFAULT_PLAN=free
# Hard-block (HTTP 429) chat runs once a non-opted-in user exceeds their monthly
# USD budget. Keep false to only track/display usage without blocking.
USAGE_LIMIT_ENFORCED=false

# Session secret — used for signing session cookies and encrypting tokens
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me-in-production

# Frontend URL (for OAuth redirect after login)
APP_URL=http://localhost:3200

# LLM provider keys (set the ones you use)
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM defaults
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-3-flash-preview

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=github_reporter

# CORS (comma-separated origins, * for all)
CORS_ORIGINS=*

# Automations
SCHEDULER_TIMEZONE=Europe/Berlin
SCHEDULER_ENABLED=true

# SMTP — used for automation email notifications.
# Works with any provider: Resend, Postmark, Sendgrid SMTP, Gmail, Mailgun, …
# Resend example:   smtp.resend.com / 587 / "resend" / <your API key>
# Postmark example: smtp.postmarkapp.com / 587 / <server token> / <server token>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM=GitHub Reporter <reports@example.com>
